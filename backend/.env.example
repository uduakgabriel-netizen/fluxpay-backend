# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/fluxpay"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ─── Solana Network ─────────────────────────────────────────
# "devnet" or "mainnet-beta"
SOLANA_NETWORK="devnet"

# ─── Solana RPC Endpoints (Multi-Endpoint Failover) ─────────
# Primary: Dedicated RPC (Helius/QuickNode) — paid, high reliability
SOLANA_RPC_PRIMARY="https://api.devnet.solana.com"
# Secondary: Alternative dedicated RPC — different provider
SOLANA_RPC_SECONDARY="https://api.devnet.solana.com"
# Fallback: Public endpoint — last resort
SOLANA_RPC_FALLBACK="https://api.devnet.solana.com"

# Legacy (still supported for backwards compatibility)
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_RPC_DEVNET="https://api.devnet.solana.com"

# ─── FluxPay Wallet (GAS FEES ONLY — Non-Custodial) ────────
# This wallet ONLY holds SOL for gas fees. Never holds customer funds.
# Supports hex-encoded, base64, or JSON array format
FLUXPAY_WALLET_PRIVATE_KEY="your-private-key-hex-or-json-array"
FLUXPAY_WALLET_PUBLIC_KEY="your-public-key-base58"

# ─── Helius (Real-time Solana transaction detection) ────────
HELIUS_API_KEY="your-helius-api-key"
HELIUS_WEBHOOK_ID="your-webhook-id"

# ─── Jupiter (Token swap aggregator) ────────────────────────
JUPITER_API_URL="https://quote-api.jup.ag/v6"

# ─── Encryption (AES-256-GCM) ──────────────────────────────
# 32 bytes in hex = 64 hex chars
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-encryption-key"

# ─── Redis (BullMQ webhook queue) ───────────────────────────
# Leave empty to use in-memory fallback
REDIS_URL="redis://127.0.0.1:6379"

# ─── Discord Alerts (Admin) ────────────────────────────────
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
ALERT_SWAP_FAILURE_THRESHOLD="5"
ALERT_WALLET_BALANCE_THRESHOLD="0.1"

# ─── Resend Email (Merchant Notifications) ──────────────────
# Sign up at https://resend.com — free tier: 3000 emails/month
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@fluxpay.com"

# ─── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─── Settlement Configuration ───────────────────────────────
# In non-custodial mode, settlement is instant (via Jupiter swap)
# These are only used for optional batch settlement
MIN_SETTLEMENT_AMOUNT="10"
SETTLEMENT_FEE_RATE="0.005"

# ─── Webhook Configuration ──────────────────────────────────
WEBHOOK_TIMEOUT_MS="10000"

# ─── Refund Configuration ───────────────────────────────────
REFUND_WINDOW_DAYS="30"

# ─── Cron Jobs ──────────────────────────────────────────────
RUN_SETTLEMENT_ON_BOOT="false"
